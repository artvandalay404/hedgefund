# Alpaca paper trading credentials — https://app.alpaca.markets/paper-trading
APCA_API_KEY_ID=your_key_here
APCA_API_SECRET_KEY=your_secret_here

# Resend transactional email — https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Email addresses
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=you@example.com

# Anthropic LLM — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here

# Database — set by fly postgres attach on Fly.io; use sqlite for local dev
DATABASE_URL=sqlite:///./dev.db

# Optional overrides (defaults are production-safe)
# RISK_PER_TRADE=0.005
# MAX_POSITIONS=8
# MAX_NOTIONAL_PCT=0.15
# MAX_HEAT=0.04
# KILL_SWITCH_DRAWDOWN=0.10
# KILL_SWITCH_DAILY_LOSS=0.03
# BREAKOUT_LOOKBACK=20
# VOLUME_MULTIPLIER=1.5
# VOLUME_LOOKBACK=50
# REWARD_RISK=2.0
# STOP_PCT=0.02
